# ===============================================
# Gold Signal Tracker - Environment Variables
# Copy this file to backend\.env and fill values
# ===============================================

# -- Telegram (get from https://my.telegram.org/apps) --
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_CHANNELS=channel_username1
TELEGRAM_SESSION=gold_tracker_session

# -- Claude API (get from https://console.anthropic.com) --
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# -- Supabase (get from https://app.supabase.com -> Settings -> API) --
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# -- Price Data (at least one required) --
# Twelve Data: https://twelvedata.com (free 800 req/day)
TWELVE_DATA_KEY=your_twelve_data_key

# Alpha Vantage: https://alphavantage.co (free 25 req/day)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# -- App --
BACKEND_PORT=8000
API_SECRET_KEY=change-this-to-random-string-32chars
FRONTEND_URL=http://localhost:5173

# -- Settings --
PRICE_FETCH_INTERVAL=60
SIGNAL_EXPIRY_HOURS=24
ANALYZER_INTERVAL=60
